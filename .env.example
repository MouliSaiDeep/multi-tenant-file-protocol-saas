# A 32-byte (64-character hex) key for AES-256-GCM encryption.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# NextAuth.js configuration
# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# SQLite path used by app and migration scripts
DATABASE_PATH=/app/db/prod.db
